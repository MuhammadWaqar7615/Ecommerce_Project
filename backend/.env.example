# Backend environment variables for development and production
# Rename this file to .env and set values before running the backend.

# Server settings
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/crafts_delights

# JWT authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Frontend origin used by backend redirects and email links
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173

# Email / SMTP settings (Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@yourdomain.com

# Google OAuth settings
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:5000/auth/google/callback
