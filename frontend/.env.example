# Frontend environment variables for Vite
# Rename this file to .env and set values before running the frontend.

# Base backend API URL used by frontend HTTP requests
VITE_API_URL=http://localhost:5000/api

# If your frontend handles OAuth callback on a specific route,
# set this to your frontend app URL. Not required by current code,
# but useful for future callback route handling.
VITE_FRONTEND_URL=http://localhost:5173

# Stripe Payment Integration
# Stripe Publishable Key (get from https://dashboard.stripe.com/account/apikeys)
# This is safe to expose publicly
VITE_STRIPE_PUBLIC_KEY=pk_test_your_public_key_here

# Redirect URL after successful payment
# This is where Stripe will redirect the user after payment completion
VITE_PAYMENT_SUCCESS_URL=http://localhost:5173/payment-success

# Redirect URL if payment is cancelled
VITE_PAYMENT_CANCEL_URL=http://localhost:5173/checkout
