# Frontend environment variables for Vite
# Rename this file to .env and set values before running the frontend.

# Base backend API URL used by frontend HTTP requests
VITE_API_URL=http://localhost:5000/api

# If your frontend handles OAuth callback on a specific route,
# set this to your frontend app URL. Not required by current code,
# but useful for future callback route handling.
VITE_FRONTEND_URL=http://localhost:5173
